            sh:order 11 ;
            sh:path dcterms:modified ] ;
    sh:targetClass bibo:Table .

cito:Citation a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing the context of a citation within a section. Contains citation type, position, and surrounding text." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Surrounding text context of the citation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pyeuropepmc:contextText ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Paper being cited" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path cito:isCitedBy ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:integer ;
            sh:description "NIF begin offset for text alignment" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nif:beginIndex ],
        [ sh:description "Type of citation relationship" ;
            sh:in ( "cites" "cites_as_evidence" "cites_as_background" "cites_as_related" "cites_as_method" "cites_for_information" "shares_authors" "agrees_with" "disagrees_with" "cites_as_metadata" "cites_as_data" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path cito:citationType ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path rdf:type ],
        [ sh:class bibo:DocumentPart ;
            sh:description "Section containing the citation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path cito:cites ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for citation type classification" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pyeuropepmc:confidenceScore ],
        [ sh:datatype xsd:integer ;
            sh:description "NIF end offset for text alignment" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nif:endIndex ] ;
    sh:targetClass cito:Citation .

org:Organization a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing an institution with ROR alignment. Contains organizational metadata and geographic information." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "GRID identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pyeuropepmc:gridId ],
        [ sh:datatype xsd:string ;
            sh:description "City name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path geo1:city ],
        [ sh:datatype xsd:string ;
            sh:description "ISO country code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path geo1:countryCode ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:description "ROR (Research Organization Registry) identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pyeuropepmc:rorId ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Wikidata identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path owl:sameAs ],
        [ sh:datatype xsd:decimal ;
            sh:description "Geographic latitude" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path geo1:lat ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "ISNI identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pyeuropepmc:isni ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Institution website URL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path foaf:homepage ],
        [ sh:class foaf:Person ;
            sh:description "Members of an institution" ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path org:hasMember ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:integer ;
            sh:description "Year established" ;
            sh:maxCount 1 ;
            sh:maxInclusive 9999 ;
            sh:minInclusive 1000 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path dcterms:created ],
        [ sh:datatype xsd:string ;
            sh:description "FundRef identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pyeuropepmc:fundrefId ],
        [ sh:datatype xsd:string ;
            sh:description "OpenAlex identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:openalex ],
        [ sh:datatype xsd:string ;
            sh:description "Display name of the institution" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path skos:prefLabel ],
        [ sh:datatype xsd:string ;
            sh:description "Institution domains" ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:subject ],
        [ sh:description "Type of institution" ;
            sh:in ( "education" "healthcare" "company" "government" "nonprofit" "facility" "other" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path org:classification ],
        [ sh:datatype xsd:string ;
            sh:description "Country name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path geo1:country ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:decimal ;
            sh:description "Geographic longitude" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path geo1:long ] ;
    sh:targetClass org:Organization .

foaf:Person a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing an author with FOAF alignment. Contains personal information, institutional affiliations, and identifiers." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Data sources for author information" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path prov:hadPrimarySource ],
        [ sh:description "Specific roles or contributions of the author" ;
            sh:in ( "conceptualization" "methodology" "software" "validation" "formal_analysis" "investigation" "resources" "data_curation" "writing_original_draft" "writing_review_editing" "visualization" "supervision" "project_administration" "funding_acquisition" ) ;
            sh:order 15 ;
            sh:path pyeuropepmc:authorRoles ],
        [ sh:datatype xsd:string ;
            sh:description "First/given name of the author" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path foaf:givenName ],
        [ sh:datatype xsd:integer ;
            sh:description "Total citation count" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pyeuropepmc:citationCount ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path prov:hadPrimarySource ],
        [ sh:description "Author position/role" ;
            sh:in ( "first" "middle" "last" "corresponding" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path org:role ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "ORCID identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path datacite:orcid ;
            sh:pattern "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[\\dX]$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Journal h-index" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pyeuropepmc:hIndex ],
        [ sh:datatype xsd:string ;
            sh:description "Author's initials" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path foaf:initials ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path prov:hadPrimarySource ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Papers authored by an author" ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path foaf:made ],
        [ sh:datatype xsd:string ;
            sh:description "Last/family name of the author" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path foaf:familyName ],
        [ sh:class org:Organization ;
            sh:description "Institutions affiliated with an author" ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path pyeuropepmc:affiliatedWith ],
        [ sh:datatype xsd:string ;
            sh:description "Semantic Scholar paper ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pyeuropepmc:semanticScholarId ],
        [ sh:datatype xsd:string ;
            sh:description "Email address" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path foaf:mbox ;
            sh:pattern "^[\\w\\.-]+@[\\w\\.-]+\\.\\w+$" ],
        [ sh:datatype xsd:string ;
            sh:description "OpenAlex identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path datacite:openalex ],
        [ sh:datatype xsd:string ;
            sh:description "Full name of the author" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path foaf:name ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:description "Affiliation text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pyeuropepmc:affiliationText ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for author data completeness and accuracy" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pyeuropepmc:qualityScore ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path dcterms:modified ] ;
    sh:targetClass foaf:Person .

bibo:DocumentPart a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing a document section with BIBO and NIF alignment. Contains section content and NIF text offsets for alignment." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class cito:Citation ;
            sh:description "Citations within a section" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path cito:cites ],
        [ sh:datatype xsd:string ;
            sh:description "Section text content" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nif:isString ],
        [ sh:datatype xsd:string ;
            sh:description "Work or entity title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:integer ;
            sh:description "NIF end offset for text alignment" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nif:endIndex ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:integer ;
            sh:description "NIF begin offset for text alignment" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nif:beginIndex ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path dcterms:modified ],
        [ sh:description "Type/category of the section" ;
            sh:in ( "abstract" "introduction" "methods" "results" "discussion" "conclusion" "acknowledgments" "references" "supplementary" "appendix" "other" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path dcterms:type ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Paper containing a section" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcterms:isPartOf ],
        [ sh:class cito:Citation ;
            sh:description "Detailed citation contexts within this section" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pyeuropepmc:citationContext ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path rdf:type ],
        [ sh:class bibo:DocumentPart ;
            sh:description "Parent section of a subsection" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path dcterms:isPartOf ],
        [ sh:class bibo:DocumentPart ;
            sh:description "Subsections of a section" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path dcterms:hasPart ] ;
    sh:targetClass bibo:DocumentPart .

bibo:AcademicArticle a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing an academic paper with BIBO alignment. Contains bibliographic metadata, citation information, and relationships to authors, institutions, journals, and other entities." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 64 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:date ;
            sh:description "First index date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path pyeuropepmc:firstIndexDate ],
        [ sh:class bibo:Journal ;
            sh:description "Journal of a paper" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 43 ;
            sh:path bibo:journal ],
        [ sh:datatype xsd:integer ;
            sh:description "Total citation count" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pyeuropepmc:citationCount ],
        [ sh:datatype xsd:integer ;
            sh:description "Influential citation count" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pyeuropepmc:influentialCitationCount ],
        [ sh:datatype xsd:string ;
            sh:description "Work or entity title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has text-mined accession numbers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path pyeuropepmc:hasTmAccessionNumbers ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "License information" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path dcterms:license ],
        [ sh:datatype xsd:string ;
            sh:description "License description text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path dcterms:rights ],
        [ sh:datatype xsd:string ;
            sh:description "Last page number" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path bibo:pageEnd ],
        [ sh:datatype xsd:string ;
            sh:description "Journal ISSN identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path bibo:issn ;
            sh:pattern "^\\d{4}-\\d{3}[\\dX]$" ],
        [ sh:class bibo:Table ;
            sh:description "Tables in a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 46 ;
            sh:path dcterms:hasPart ],
        [ sh:datatype xsd:string ;
            sh:description "Semantic Scholar corpus ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pyeuropepmc:semanticScholarCorpusId ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of references cited" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path bibo:numPages ],
        [ sh:datatype xsd:date ;
            sh:description "Publication date (legacy field)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has database cross-references" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path pyeuropepmc:hasDbCrossReferences ],
        [ sh:class bibo:Article ;
            sh:description "References cited by a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 45 ;
            sh:path cito:cites ],
        [ sh:class frapo:Grant ;
            sh:description "Grants funding a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 48 ;
            sh:path foaf:fundedBy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper is in Europe PMC" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path pyeuropepmc:inEpmc ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:string ;
            sh:description "Related work IDs" ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path dcterms:related ],
        [ sh:datatype xsd:float ;
            sh:description "Overall quality score for paper data completeness and accuracy" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path pyeuropepmc:qualityScore ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed Central ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path pyeuropepmc:pmcid ;
            sh:pattern "^PMC\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "External identifiers from various sources" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path pyeuropepmc:externalIds ],
        [ sh:datatype xsd:integer ;
            sh:description "Publication year (4-digit)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 9999 ;
            sh:minInclusive 1000 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has a PDF available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path pyeuropepmc:hasPdf ],
        [ sh:datatype xsd:string ;
            sh:description "ISSN identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path bibo:issn ;
            sh:pattern "^\\d{4}-\\d{3}[\\dX]$" ],
        [ sh:description "Open access status details" ;
            sh:in ( "open" "closed" "hybrid" "green" "gold" "bronze" "unknown" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path dcterms:accessRights ],
        [ sh:datatype xsd:string ;
            sh:description "OpenAlex identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path datacite:openalex ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has references" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path pyeuropepmc:hasReferences ],
        [ sh:datatype xsd:string ;
            sh:description "Article abstract" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:abstract ],
        [ sh:datatype xsd:string ;
            sh:description "Publisher name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper is in PubMed Central" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path pyeuropepmc:inPmc ],
        [ sh:class org:Organization ;
            sh:description "Institutions affiliated with a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 42 ;
            sh:path pyeuropepmc:affiliatedWith ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Open access URL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path bibo:uri ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has supplementary materials" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path pyeuropepmc:hasSupplementary ],
        [ sh:datatype xsd:string ;
            sh:description "Page range (e.g., \"123-456\")" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path bibo:pages ],
        [ sh:datatype xsd:string ;
            sh:description "Fields of study" ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path rdf:type ],
        [ sh:class bibo:Image ;
            sh:description "Figures in a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 47 ;
            sh:path dcterms:hasPart ],
        [ sh:class bibo:DocumentPart ;
            sh:description "Sections of a paper" ;
            sh:nodeKind sh:IRI ;
            sh:order 44 ;
            sh:path dcterms:hasPart ],
        [ sh:datatype xsd:string ;
            sh:description "Conflicts in external identifiers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path pyeuropepmc:externalIdConflicts ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has labs links" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path pyeuropepmc:hasLabsLinks ],
        [ sh:datatype xsd:date ;
            sh:description "Full publication date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path dcterms:date ],
        [ sh:datatype xsd:string ;
            sh:description "Journal issue number" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path bibo:issue ],
        [ sh:datatype xsd:boolean ;
            sh:description "Open access status flag" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:accessRights ],
        [ sh:description "Type of publication" ;
            sh:in ( "journal_article" "review" "preprint" "book_chapter" "conference_paper" "dataset" "thesis" "other" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path bibo:DocumentType ],
        [ sh:class foaf:Person ;
            sh:description "Authors of a work" ;
            sh:nodeKind sh:IRI ;
            sh:order 41 ;
            sh:path dcterms:creator ],
        [ sh:datatype xsd:date ;
            sh:description "First publication date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path pyeuropepmc:firstPublicationDate ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path pyeuropepmc:pmid ;
            sh:pattern "^\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Research topics from OpenAlex" ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:string ;
            sh:description "First page number" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path bibo:pageStart ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Digital Object Identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path bibo:doi ;
            sh:pattern "^10\\.\\d{4,9}/[-._;()/:A-Z0-9]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "MeSH terms associated with the paper" ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path mesh:meshHeading ],
        [ sh:datatype xsd:string ;
            sh:description "List of keywords" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of papers citing this work" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pyeuropepmc:citationCount ],
        [ sh:datatype xsd:anyURI ;
            sh:description "License URL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path dcterms:license ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the paper has text-mined terms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path pyeuropepmc:hasTextMinedTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Publication volume" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 52 ;
            sh:path bibo:volume ],
        [ sh:datatype xsd:string ;
            sh:description "List of publication types from Europe PMC" ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path bibo:DocumentType ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Semantic Scholar paper ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path pyeuropepmc:semanticScholarId ],
        [ sh:datatype xsd:string ;
            sh:description "Page information string" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path bibo:pages ] ;
    sh:targetClass bibo:AcademicArticle .
