            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Table label (e.g., \"Table 1\")" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Caption or description" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path prov:hadPrimarySource ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Paper containing a table" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcterms:isPartOf ],
        [ sh:datatype xsd:string ;
