@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix datacite: <http://purl.org/spar/datacite/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix frapo: <http://purl.org/cerif/frapo/> .
@prefix geo1: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix mesh: <http://id.nlm.nih.gov/mesh/> .
@prefix nif: <http://persistence.uni-leipzig.org/nlp2rdf/ontologies/nif-core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix pyeuropepmc: <https://w3id.org/pyeuropepmc/vocab#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bibo:Document a sh:NodeShape ;
    sh:closed false ;
    sh:description "Base entity for scholarly works (papers, references, etc.). Provides common fields and methods for entities representing scholarly publications." ;
    sh:ignoredProperties ( pyeuropepmc:hasTmAccessionNumbers dcterms:license dcterms:rights pyeuropepmc:qualityScore mesh:meshHeading bibo:pageStart pyeuropepmc:hasReferences pyeuropepmc:inPmc cito:isCitedBy bibo:authorList dcterms:creator dcterms:subject pyeuropepmc:hasTextMinedTerms pyeuropepmc:externalIds dcterms:publisher datacite:openalex dcterms:abstract dcterms:accessRights bibo:DocumentType pyeuropepmc:firstIndexDate rdf:type cito:cites pyeuropepmc:firstPublicationDate pyeuropepmc:citationCount pyeuropepmc:semanticScholarCorpusId pyeuropepmc:hasLabsLinks dcterms:hasPart foaf:fundedBy dcterms:description pyeuropepmc:inEpmc dcterms:related pyeuropepmc:influentialCitationCount pyeuropepmc:hasPdf pyeuropepmc:hasDbCrossReferences bibo:numPages bibo:issue bibo:uri pyeuropepmc:hasSupplementary pyeuropepmc:externalIdConflicts bibo:journal bibo:pageEnd bibo:issn pyeuropepmc:affiliatedWith ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed Central ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pyeuropepmc:pmcid ;
            sh:pattern "^PMC\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Semantic Scholar paper ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pyeuropepmc:semanticScholarId ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:integer ;
            sh:description "Publication year (4-digit)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 9999 ;
            sh:minInclusive 1000 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pyeuropepmc:pmid ;
            sh:pattern "^\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Page range (e.g., \"123-456\")" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path bibo:pages ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Digital Object Identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path bibo:doi ;
            sh:pattern "^10\\.\\d{4,9}/[-._;()/:A-Z0-9]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Publication volume" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path bibo:volume ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:date ;
            sh:description "Full publication date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:date ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Work or entity title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:title ] ;
    sh:targetClass bibo:Document .

pyeuropepmc:BaseEntity a sh:NodeShape ;
    sh:closed false ;
    sh:description "Base entity for all data models with RDF serialization support. All entities inherit from this base class, providing common functionality for validation, normalization, and RDF export." ;
    sh:ignoredProperties ( bibo:doi pyeuropepmc:hasTmAccessionNumbers dcterms:rights geo1:city datacite:orcid mesh:meshHeading pyeuropepmc:publisherId bibo:isoAbbrev owl:sameAs bibo:authorList pyeuropepmc:pmcid foaf:made pyeuropepmc:hasTextMinedTerms dcterms:language pyeuropepmc:externalIds pyeuropepmc:rorId pyeuropepmc:hIndex geo1:countryCode datacite:openalex dcterms:abstract foaf:familyName rdf:type cito:cites frapo:hasFundingAgency pyeuropepmc:semanticScholarCorpusId pyeuropepmc:hasLabsLinks dcterms:hasPart pyeuropepmc:sjr foaf:fundedBy foaf:depiction dcterms:description pyeuropepmc:inEpmc org:role dcterms:title dcterms:related pyeuropepmc:fundrefId org:classification pyeuropepmc:hasDbCrossReferences bibo:nlmTA bibo:numPages bibo:pages bibo:issue pyeuropepmc:hasSupplementary datacite:doi pyeuropepmc:externalIdConflicts dcterms:isPartOf pyeuropepmc:scopusSourceId bibo:issn bibo:volume pyeuropepmc:contextText dcterms:license bibo:nlmid dcterms:issued pyeuropepmc:gridId frapo:funds bibo:shortTitle pyeuropepmc:qualityScore pyeuropepmc:isni cito:citationType bibo:pageStart pyeuropepmc:confidenceScore pyeuropepmc:inPmc pyeuropepmc:hasReferences cito:isCitedBy bibo:article rdfs:member dcterms:creator datacite:identifier dcterms:subject geo1:long dcterms:type pyeuropepmc:semanticScholarId dcterms:publisher skos:prefLabel pyeuropepmc:authorRoles nif:endIndex dcterms:accessRights pyeuropepmc:affiliationText foaf:homepage frapo:hasRecipient bibo:DocumentType pyeuropepmc:firstIndexDate foaf:mbox pyeuropepmc:firstPublicationDate pyeuropepmc:citationCount org:hasMember dcterms:created nif:isString dcterms:date pyeuropepmc:influentialCitationCount pyeuropepmc:hasPdf geo1:lat geo1:country foaf:initials bibo:eissn bibo:uri pyeuropepmc:impactFactor foaf:givenName nif:beginIndex pyeuropepmc:pmid bibo:journal bibo:pageEnd pyeuropepmc:citationContext foaf:name pyeuropepmc:affiliatedWith ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pyeuropepmc:confidence ] ;
    sh:targetClass pyeuropepmc:BaseEntity .

frapo:Grant a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing a research grant or funding award with FRAPO alignment. Contains funding information and relationships to recipients." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "FundRef DOI for the funding organization" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path datacite:doi ;
            sh:pattern "^10\\.\\d{4,9}/[-._;()/:A-Z0-9]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the funding organization/source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path frapo:hasFundingAgency ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Papers funded by a grant" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path frapo:funds ],
        [ sh:datatype xsd:string ;
            sh:description "DEPRECATED: Use recipients instead. Grant recipient name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path frapo:hasRecipient ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:description "Grant or award identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:identifier ],
        [ sh:class foaf:Person ;
            sh:description "Recipients of a grant" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path frapo:hasRecipient ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path prov:hadPrimarySource ] ;
    sh:targetClass frapo:Grant .

bibo:Article a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing a bibliographic reference with BIBO alignment. Contains citation information for works referenced by papers." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Digital Object Identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path bibo:doi ;
            sh:pattern "^10\\.\\d{4,9}/[-._;()/:A-Z0-9]+$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Publication year (4-digit)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 9999 ;
            sh:minInclusive 1000 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:string ;
            sh:description "Raw citation text when parsing fails" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Page range (e.g., \"123-456\")" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path bibo:pages ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed Central ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pyeuropepmc:pmcid ;
            sh:pattern "^PMC\\d+$" ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:description "Semantic Scholar paper ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pyeuropepmc:semanticScholarId ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Author list (comma-separated)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path bibo:authorList ],
        [ sh:datatype xsd:string ;
            sh:description "PubMed ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pyeuropepmc:pmid ;
            sh:pattern "^\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Publication volume" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path bibo:volume ],
        [ sh:datatype xsd:string ;
            sh:description "Work or entity title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:date ;
            sh:description "Full publication date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:date ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Paper that cites this reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path cito:isCitedBy ] ;
    sh:targetClass bibo:Article .

bibo:Journal a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing an academic journal with BIBO alignment. Contains journal metadata and bibliometric information." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "SCImago Journal Rank" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pyeuropepmc:sjr ],
        [ sh:datatype xsd:string ;
            sh:description "Publisher name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "NLM Title Abbreviation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path bibo:nlmTA ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Wikidata identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path owl:sameAs ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "Europe PMC journal issue identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path bibo:issue ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path dcterms:modified ],
        [ sh:class bibo:AcademicArticle ;
            sh:description "Papers published in a journal" ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path bibo:article ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:description "ISO abbreviation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path bibo:shortTitle ],
        [ sh:datatype xsd:integer ;
            sh:description "Journal h-index" ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pyeuropepmc:hIndex ],
        [ sh:datatype xsd:string ;
            sh:description "Subject areas/categories" ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:string ;
            sh:description "OpenAlex identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path datacite:openalex ],
        [ sh:datatype xsd:decimal ;
            sh:description "Journal impact factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pyeuropepmc:impactFactor ],
        [ sh:datatype xsd:string ;
            sh:description "Work or entity title" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Medline abbreviation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path bibo:shortTitle ],
        [ sh:datatype xsd:string ;
            sh:description "Publisher identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pyeuropepmc:publisherId ],
        [ sh:datatype xsd:string ;
            sh:description "NLM ID (National Library of Medicine identifier)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path bibo:nlmid ],
        [ sh:datatype xsd:string ;
            sh:description "Electronic ISSN" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path bibo:eissn ;
            sh:pattern "^\\d{4}-\\d{3}[\\dX]$" ],
        [ sh:datatype xsd:string ;
            sh:description "Scopus source identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pyeuropepmc:scopusSourceId ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "ISSN identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path bibo:issn ;
            sh:pattern "^\\d{4}-\\d{3}[\\dX]$" ],
        [ sh:datatype xsd:string ;
            sh:description "Country name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path geo1:country ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Primary language of publication" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:language ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "ISO abbreviation (alternative field)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path bibo:isoAbbrev ] ;
    sh:targetClass bibo:Journal .

bibo:Row a sh:NodeShape ;
    sh:closed true ;
    sh:description "Entity representing a table row." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Cell values for a table row" ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:member ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for extracted information (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pyeuropepmc:confidence ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Source URI for provenance tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path prov:hadPrimarySource ],
        [ sh:datatype xsd:string ;
            sh:description "List of data sources that contributed to this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path prov:hadPrimarySource ],
        [ sh:class bibo:Table ;
            sh:description "Table containing a row" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path dcterms:isPartOf ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp of last data update (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:modified ],
        [ sh:datatype xsd:string ;
            sh:description "Local identifier (slug/uuid) for the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:description "RDF types (CURIEs/URIs) for this entity" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path rdf:type ] ;
    sh:targetClass bibo:Row .

bibo:Image a sh:NodeShape ;
