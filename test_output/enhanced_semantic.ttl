            <https://w3id.org/pyeuropepmc/data#author/merwood-a>,
            <https://w3id.org/pyeuropepmc/data#author/tomescustachie-s>,
            <https://w3id.org/pyeuropepmc/data#author/tyndall-i> ;
        dcterms:issued 2025 ;
