            <https://w3id.org/pyeuropepmc/data#author/ruggeri-fs> ;
        dcterms:issued 2025 ;
        dcterms:subject "Amyloidogenic Proteins",
            "Atomic force microscopy",
            "Biomolecular Processes",
            "Cancer Diseases",
            "Force Spectroscopy",
            "Nano‐Chemical Analysis",
            "Neurodegeneration" ;
        dcterms:title "Nanoscale Analysis beyond Imaging by Atomic Force Microscopy: Molecular Perspectives on Oncology and Neurodegeneration."^^xsd:string ;
        bibo:doi "10.1002/smsc.202500351"^^xsd:anyURI ;
