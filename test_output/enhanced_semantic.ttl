<https://w3id.org/pyeuropepmc#provenance> {
    frapo:Grant rdfs:subClassOf pyeuropepmc:BaseEntity .

    bibo:AcademicArticle rdfs:subClassOf bibo:Document,
            pyeuropepmc:BaseEntity .

    bibo:Article rdfs:subClassOf bibo:Document,
            pyeuropepmc:BaseEntity .

    bibo:DocumentPart rdfs:subClassOf pyeuropepmc:BaseEntity .

    bibo:Image rdfs:subClassOf pyeuropepmc:BaseEntity .

    bibo:Journal rdfs:subClassOf pyeuropepmc:BaseEntity .

    bibo:Row rdfs:subClassOf pyeuropepmc:BaseEntity .

    bibo:Table rdfs:subClassOf pyeuropepmc:BaseEntity .

    cito:Citation rdfs:subClassOf pyeuropepmc:BaseEntity .

    org:Organization rdfs:subClassOf pyeuropepmc:BaseEntity .

    foaf:Person rdfs:subClassOf pyeuropepmc:BaseEntity .

    pyeuropepmc:PaperShape a ns2:NodeShape ;
        ns2:property pyeuropepmc:doiProperty,
            pyeuropepmc:titleProperty ;
        ns2:targetClass <http://example.org/fabio#ResearchPaper> .

    pyeuropepmc:dataset-v1 a prov:Entity ;
        ns1:versionInfo "1.0.0" ;
        dcterms:description "PyEuropePMC RDF dataset with semantic relationships" ;
        prov:generatedAtTime "2026-04-07T11:38:49.151709"^^xsd:dateTime ;
        prov:wasGeneratedBy pyeuropepmc:rdfGenerator .

    pyeuropepmc:quality-assessment a prov:Activity ;
        dcterms:description "Automated quality assessment of RDF entities" ;
        prov:startedAtTime "2026-04-07T11:38:49.133361"^^xsd:dateTime .

