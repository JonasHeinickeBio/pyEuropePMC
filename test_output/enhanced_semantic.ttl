            "Male",
            "Metastatic breast cancer" ;
        dcterms:title "Knowledge in Motion: A decade reviewed, a future defined - The ABC Global Alliance 2015-2025 Decade Report and 2025-2035 Global Charter."^^xsd:string ;
        bibo:doi "10.1016/j.breast.2025.104601"^^xsd:anyURI ;
