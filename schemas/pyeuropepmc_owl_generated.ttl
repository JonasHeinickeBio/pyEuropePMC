<https://w3id.org/pyeuropepmc.owl.ttl> a owl:Ontology ;
    rdfs:label "pyeuropepmc" ;
    dcterms:license "MIT" ;
    dcterms:title "PyEuropePMC Data Model Schema" ;
    pav:version "1.0.0" ;
    skos:definition "LinkML schema defining the data model for PyEuropePMC, a Python toolkit for searching, retrieving, and analyzing scientific literature from Europe PMC. This schema provides a single source of truth for generating JSON Schema, RDF/OWL, SHACL shapes, and Python dataclasses." .

