    skos:inScheme <https://w3id.org/pyeuropepmc/entities/paper> .

<https://w3id.org/pyeuropepmc/:AuthorRole> a owl:Class ;
    rdfs:label "AuthorRole" ;
    owl:unionOf ( <https://w3id.org/pyeuropepmc/:AuthorRole#conceptualization> <https://w3id.org/pyeuropepmc/:AuthorRole#methodology> <https://w3id.org/pyeuropepmc/:AuthorRole#software> <https://w3id.org/pyeuropepmc/:AuthorRole#validation> <https://w3id.org/pyeuropepmc/:AuthorRole#formal_analysis> <https://w3id.org/pyeuropepmc/:AuthorRole#investigation> <https://w3id.org/pyeuropepmc/:AuthorRole#resources> <https://w3id.org/pyeuropepmc/:AuthorRole#data_curation> <https://w3id.org/pyeuropepmc/:AuthorRole#writing_original_draft> <https://w3id.org/pyeuropepmc/:AuthorRole#writing_review_editing> <https://w3id.org/pyeuropepmc/:AuthorRole#visualization> <https://w3id.org/pyeuropepmc/:AuthorRole#supervision> <https://w3id.org/pyeuropepmc/:AuthorRole#project_administration> <https://w3id.org/pyeuropepmc/:AuthorRole#funding_acquisition> ) ;
    skos:definition "Specific roles or contributions of authors" ;
    skos:inScheme <https://w3id.org/pyeuropepmc/enums> ;
    linkml:permissible_values <https://w3id.org/pyeuropepmc/:AuthorRole#conceptualization>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#data_curation>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#formal_analysis>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#funding_acquisition>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#investigation>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#methodology>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#project_administration>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#resources>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#software>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#supervision>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#validation>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#visualization>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#writing_original_draft>,
        <https://w3id.org/pyeuropepmc/:AuthorRole#writing_review_editing> .

[] rdfs:subClassOf [ owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty <https://w3id.org/pyeuropepmc/:begin_index> ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 999999999 ] ) ] ] [ a owl:Restriction ;
                        owl:onProperty <https://w3id.org/pyeuropepmc/:end_index> ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ] ) ] ;
    owl:intersectionOf ( [ owl:intersectionOf ( [ a owl:Restriction ;
                            owl:onProperty <https://w3id.org/pyeuropepmc/:begin_index> ;
                            owl:someValuesFrom owl:Thing ] [ a owl:Restriction ;
                            owl:onProperty <https://w3id.org/pyeuropepmc/:end_index> ;
                            owl:someValuesFrom owl:Thing ] ) ] <https://w3id.org/pyeuropepmc/entities/section/SectionEntity> ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/pyeuropepmc/:title> ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ owl:intersectionOf ( [ a owl:Restriction ;
                            owl:onProperty <https://w3id.org/pyeuropepmc/:doi> ;
                            owl:someValuesFrom owl:Thing ] [ a owl:Restriction ;
                            owl:onProperty <https://w3id.org/pyeuropepmc/:pmcid> ;
                            owl:someValuesFrom owl:Thing ] ) ] <https://w3id.org/pyeuropepmc/entities/paper/PaperEntity> ) .
