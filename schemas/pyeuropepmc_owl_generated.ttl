                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty <https://w3id.org/pyeuropepmc/slots/affiliation_order> ],
        [ a owl:Restriction ;
