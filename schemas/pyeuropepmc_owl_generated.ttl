    skos:definition "Confidence score for extracted information (0.0 to 1.0)" ;
    skos:inScheme <https://w3id.org/pyeuropepmc/slots> .

<https://w3id.org/pyeuropepmc/slots/confidence_score> a owl:DatatypeProperty ;
